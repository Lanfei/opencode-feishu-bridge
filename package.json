  },
  "homepage": "https://github.com/Lanfei/opencode-feishu-bridge#readme",
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
