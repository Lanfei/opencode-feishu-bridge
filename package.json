{
  "name": "opencode-feishu-bridge",
  "version": "1.0.1",
  "description": "Feishu bridge for OpenCode",
  "main": "dist/main.js",
  "files": [
    "dist",
    "bin",
    "README.md",
    "config.example.json"
  ],
  "bin": {
    "opencode-feishu-bridge": "bin/opencode-attach.js",
    "ofbc": "bin/opencode-attach.js",
    "ofbs": "bin/opencode-feishu-start.js"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "attach": "node ./bin/opencode-attach.js"
  },
  "keywords": [
